# Optional overrides for the Edge Impulse API hosts. These are only defaults;
# per-session overrides can also be supplied via the connect form or URL params
# (studioHost / ingestionHost). No secrets are ever committed — the API key is
# supplied at runtime and stored only in the httpOnly `ei_session` cookie.

# Edge Impulse Studio API base (default: https://studio.edgeimpulse.com/v1/api)
EI_STUDIO_HOST=

# Edge Impulse Ingestion API base (default: https://ingestion.edgeimpulse.com/api)
EI_INGESTION_HOST=

# Host overrides (studioHost / ingestionHost from env, the connect form, or URL
# params) are only honored when their hostname is edgeimpulse.com (or a
# subdomain). To allow a self-hosted / enterprise Edge Impulse instance, add its
# bare hostname(s) here (comma-separated). This prevents the API key from being
# sent to an attacker-controlled host (SSRF / key exfiltration).
# Example: EI_ALLOWED_HOSTS=studio.acme.internal,ingestion.acme.internal
EI_ALLOWED_HOSTS=
