# Optional overrides for the Edge Impulse API hosts. These are only defaults;
# per-session overrides can also be supplied via the connect form or URL params
# (studioHost / ingestionHost). No secrets are ever committed — the API key is
# supplied at runtime and stored only in the httpOnly `ei_session` cookie.

# Edge Impulse Studio origin (default: https://studio.edgeimpulse.com).
# The app appends /v1/api; do not include it here.
EI_STUDIO_HOST=

# Edge Impulse Ingestion origin (default: https://ingestion.edgeimpulse.com).
# The app appends /api; do not include it here.
EI_INGESTION_HOST=
